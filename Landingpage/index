<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <title>Página Web Profesional por $97</title>
    
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>

    <style>
        /* Gradiente de fondo suave y profesional */
        .gradient-bg {
            background: linear-gradient(135deg, #121212 0%, #1e1e1e 50%, #121212 100%);
            min-height: 100vh;
        }

        /* Efectos de texto */
        .price-highlight {
            background: linear-gradient(90deg, #FFD700, #FFA500);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            font-weight: 800;
        }

        /* Animación de flotación para iconos decorativos */
        .floating-element {
            animation: float 6s ease-in-out infinite;
        }

        @keyframes float {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-20px); }
        }

        /* Icono de fondo grande y sutil */
        .web-icon-bg {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) rotate(-15deg);
            font-size: 40vw;
            opacity: 0.03;
            pointer-events: none;
        }
    </style>
</head>

<body class="gradient-bg text-white font-sans antialiased overflow-x-hidden">

    <main class="relative flex flex-col items-center justify-center min-h-screen p-6 md:p-16 text-center">
        
        <div class="web-icon-bg">
            <i class="fas fa-globe"></i>
        </div>
        
        <div class="absolute top-10 right-10 floating-element hidden md:block">
            <i class="fas fa-code text-5xl text-gray-400 opacity-20"></i>
        </div>
        
        <div class="absolute bottom-10 left-10 floating-element hidden md:block" style="animation-delay: 2s;">
            <i class="fas fa-server text-5xl text-gray-400 opacity-20"></i>
        </div>

        <div class="z-10 max-w-4xl">
            <h1 class="text-4xl md:text-7xl font-extrabold tracking-tight mb-4 leading-tight">
                Página Web Profesional
                <span class="price-highlight block mt-2 text-5xl md:text-8xl">por $97</span>
            </h1>

            <div class="h-1.5 w-24 md:w-32 bg-gradient-to-r from-green-400 to-emerald-600 mx-auto my-8 rounded-full"></div>

            <p class="text-xl md:text-2xl font-light mb-12 text-gray-300 max-w-2xl mx-auto">
                Lleva tu negocio al siguiente nivel con todo incluido: 
                <span class="text-white font-semibold">Hosting, Dominio y Soporte Express.</span>
            </p>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-12">
                <div class="flex flex-col items-center p-4">
                    <i class="fas fa-check-circle text-green-400 text-4xl mb-4"></i>
                    <h3 class="text-lg font-medium">Hosting Premium</h3>
                </div>
                <div class="flex flex-col items-center p-4">
                    <i class="fas fa-check-circle text-green-400 text-4xl mb-4"></i>
                    <h3 class="text-lg font-medium">Dominio por 1 Año</h3>
                </div>
                <div class="flex flex-col items-center p-4">
                    <i class="fas fa-check-circle text-green-400 text-4xl mb-4"></i>
                    <h3 class="text-lg font-medium">Soporte de 1 Mes</h3>
                </div>
            </div>

            <div class="mt-16">
                <a href="#" class="bg-white text-black px-10 py-4 rounded-full font-bold text-lg hover:bg-gray-200 transition-all transform hover:scale-105 shadow-xl">
                    ¡Quiero mi página hoy!
                </a>
            </div>
        </div>

        <footer class="absolute bottom-6 w-full px-8 flex justify-between items-center text-xs md:text-sm text-gray-500 uppercase tracking-widest">
            <p>© 2024 Tu Marca</p>
            <p class="text-gray-400">Oferta válida por tiempo limitado</p>
        </footer>
    </main>

</body>
</html>
